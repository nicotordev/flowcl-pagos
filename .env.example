# Secreto de la API de Flow
FLOW_SECRET_KEY=your_secret_key
# Llave pública de la API de Flow
FLOW_PUBLIC_KEY=your_public_key
# URL de la API de Flow
FLOW_API_URL=https://sandbox.flow.cl/api

# Integración: con credenciales reales los tests de sandbox corren solos.
# Pon FLOW_RUN_INTEGRATION_TESTS=false para omitirlos.
# FLOW_RUN_INTEGRATION_TESTS=true

# Opcionales (requieren permisos extra en Flow)
# FLOW_RUN_MERCHANT_TESTS=true
# FLOW_RUN_CUSTOMER_AUTOMATIC_CHARGE_TESTS=true
# FLOW_TEST_INVOICE_ID=
# FLOW_OVERDUE_INVOICE_ID=
