{
  "name": "@nicotordev/flowcl-pagos",
  "version": "10.2.7",
  "packageManager": "bun@1.3.13",
  "description": "SDK en TypeScript para integrar pagos con la API de Flow.cl de manera sencilla y segura.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --config ./src/jest.config.cjs",
    "test:unit": "jest --config ./src/jest.config.cjs --testPathPattern=flow.unit.test",
    "test:integration": "jest --config ./src/jest.config.cjs --testPathIgnorePatterns=flow.unit.test",
    "lint": "eslint 'src/**/*.{ts,tsx,js,jsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "prepare": "husky",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,css,scss,md}'",
    "prepublishOnly": "bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/4cidkid/flowcl-pagos.git"
  },
  "keywords": [
    "flowcl",
    "pagos",
    "api",
    "typescript",
    "chile",
    "ecommerce",
    "transacciones",
    "sdk",
    "integración",
    "transbank",
    "mach",
    "khipu",
    "webpay",
    "redcompra",
    "billetera digital",
    "pagos electrónicos",
    "fintech",
    "servipag",
    "compras online",
    "pasarela de pagos"
  ],
  "author": "Nicolas Torres <nicotordev@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/qs": "^6.15.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "axios-mock-adapter": "^2.1.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.4.0",
    "qs": "^6.15.2"
  },
  "overrides": {
    "@babel/helpers": "^7.26.10",
    "diff": "^4.0.4",
    "flatted": "^3.4.2",
    "picomatch": "^2.3.2",
    "yaml": "^2.8.3"
  },
  "files": [
    "dist"
  ],
  "lint-staged": {
    "./src/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
